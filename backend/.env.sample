# --- Infrastructure Settings (Strictly Environment-Driven) ---
# These settings are immutable at runtime and cannot be changed via the API/JSON.

# FastAPI & Logging
APP_NAME=Knowledge Ingestion
DEBUG=true
REQUEST_ID_HEADER=X-Request-ID
LOG_LEVEL=INFO

# Database & Storage
# DATABASE_PATH=data/knowledge_ingestion/app.db
# DATA_DIR=data/knowledge_ingestion
# UPLOADS_DIR=data/knowledge_ingestion/uploads
# SNAPSHOTS_DIR=data/knowledge_ingestion/snapshots

# Vector Store (Weaviate)
VECTOR_STORE_PROVIDER=weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION_NAME=DocumentChunk

# Core LLM Connectivity (Chat)
OPENAI_API_KEY=your-key-here
OPENAI_API_BASE=http://localhost:11434/v1

# Core LLM Connectivity (Embeddings)
# Falls back to OPENAI_API_BASE/KEY if unset
# EMBEDDING_API_KEY=your-embedding-key
# EMBEDDING_API_BASE=http://localhost:11434/v1

# --- Feature Defaults (Overrideable via GlobalSettings/JSON) ---
# These variables provide the initial values for the system's behavior.
# They can be overridden at runtime via settings.json or the API.

# Models
CHAT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Ingestion Behavior
URL_TIMEOUT_SECONDS=10

# RAG & Retrieval
CONTEXT_WINDOW_SIZE=128000
MAX_HISTORY_TURNS=10
RETRIEVAL_K=10
RETRIEVAL_MODE=hybrid
HYBRID_WEIGHT=0.5

# Safety & Grounding Thresholds
MIN_SIMILARITY_THRESHOLD=0.1
MIN_RESULTS_COUNT=1
SAFETY_RISK_THRESHOLD=0.7
