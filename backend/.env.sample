# FastAPI
APP_NAME=Knowledge Ingestion
DEBUG=true
REQUEST_ID_HEADER=X-Request-ID
LOG_LEVEL=INFO

# Database
# DATABASE_PATH=data/knowledge_ingestion/app.db

# File Storage
# DATA_DIR=data/knowledge_ingestion
# UPLOADS_DIR=data/knowledge_ingestion/uploads
# SNAPSHOTS_DIR=data/knowledge_ingestion/snapshots

# Ingestion
URL_TIMEOUT_SECONDS=10

# --- LLM Settings ---

# OpenAI API Key (Required for OpenAI, can be dummy for some local LLMs)
OPENAI_API_KEY=sk-your-key-here

# Custom API Base URL
# Default (OpenAI): https://api.openai.com/v1
# Local LLM Example (Ollama): http://localhost:11434/v1
# Local LLM Example (LM Studio): http://localhost:1234/v1
# OPENAI_API_BASE=http://localhost:11434/v1

# Chat Model
# Examples: gpt-4o, gpt-3.5-turbo, llama3, mistral
CHAT_MODEL=gpt-4o

# Embedding Model
# Examples: text-embedding-3-small, text-embedding-3-large, nomic-embed-text
EMBEDDING_MODEL=text-embedding-3-small

# --- RAG Settings ---
CONTEXT_WINDOW_SIZE=128000
MAX_HISTORY_TURNS=10
RETRIEVAL_K=10

# Grounding & Safety Thresholds
MIN_SIMILARITY_THRESHOLD=-.02
MIN_RESULTS_COUNT=1
SAFETY_RISK_THRESHOLD=0.7

# --- Chroma Settings ---
CHROMA_DB_PATH=.chroma_db
CHROMA_COLLECTION_NAME=document-chunks
