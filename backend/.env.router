
# FastAPI
APP_NAME=Knowledge Ingestion
DEBUG=true
REQUEST_ID_HEADER=X-Request-ID
LOG_LEVEL=INFO

# Ingestion
URL_TIMEOUT_SECONDS=10

# --- LLM Settings ---

# 9Router API key from local 9Router dashboard
OPENAI_API_KEY=sk-9b3a49569d145b1c-xl93wy-4acc38b2

# 9Router OpenAI-compatible endpoint
OPENAI_API_BASE=http://localhost:20128/v1

# Optional: Dedicated embedding endpoint (falls back to OPENAI_API_BASE if unset)
EMBEDDING_API_KEY=sk-9b3a49569d145b1c-xl93wy-4acc38b2
EMBEDDING_API_BASE=http://localhost:20128/v1

# 9Router combo/model name
CHAT_MODEL=rag-combo

# Embedding Model
EMBEDDING_MODEL=mxbai-embed-large

# --- RAG Settings ---
CONTEXT_WINDOW_SIZE=128000
MAX_HISTORY_TURNS=10
RETRIEVAL_K=10
RETRIEVAL_MODE=hybrid
HYBRID_WEIGHT=0.5

# Grounding & Safety Thresholds
MIN_SIMILARITY_THRESHOLD=-0.02
MIN_RESULTS_COUNT=1
SAFETY_RISK_THRESHOLD=0.7

# --- Vector Store Settings ---
VECTOR_STORE_PROVIDER=weaviate

# --- Weaviate Settings ---
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION_NAME=DocumentChunk
